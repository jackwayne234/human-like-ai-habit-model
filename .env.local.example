# Copy this file to .env.local and put your key there.
# Never commit .env.local.

# Hermes / OpenAI-compatible option.
# Get the base URL and model name from your Hermes provider dashboard.
# API_PROVIDER=hermes
# HERMES_API_KEY=
# HERMES_BASE_URL=
# HERMES_MODEL=

# OpenAI option.
OPENAI_API_KEY=

# Optional. Keep this cheap/small for first tests.
OPENAI_MODEL=gpt-4o-mini
